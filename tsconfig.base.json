{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@chat-soft/protocol": [
        "shared/protocol/src"
      ],
      "@chat-soft/core": [
        "shared/core/src"
      ]
    }
  }
}
